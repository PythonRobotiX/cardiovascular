{
  "module": "BLOOD_PRESSURE_HOME_MONITORING_PREPARATION",
  "version": "1.0",

  "purpose": "Standardize patient preparation and measurement conditions for accurate blood pressure monitoring",

  "pre_measurement_restrictions": {
    "avoid_within_30_minutes": [
      "smoking",
      "caffeinated_beverages",
      "physical_exercise"
    ]
  },

  "patient_positioning_rules": {
    "body_position": {
      "seated": true,
      "back_supported": true,
      "feet_flat_on_floor": true,
      "legs_crossed": false,
      "minimum_rest_before_measurement_minutes": 5
    },

    "arm_position": {
      "arm_supported": true,
      "cuff_on_bare_arm": true,
      "cuff_position": "lower_edge_above_antecubital_fossa",
      "arm_height": "heart_level"
    }
  },

  "behavioral_restrictions_during_measurement": {
    "do_not": [
      "talk",
      "use_phone",
      "watch_tv",
      "perform_any_activity"
    ]
  },

  "measurement_protocol": {
    "frequency": {
      "daily_sessions": 2,
      "morning_session": {
        "timing": "after_voiding_bladder AND before_medications AND before_food"
      },
      "bedtime_session": {
        "timing": "before_sleep"
      }
    },

    "readings_per_session": {
      "count": 2,
      "interval_minutes": 1
    },

    "total_daily_readings": 4
  },

  "monitoring_duration": {
    "minimum_days": 3,
    "recommended_days": 7,
    "pre_clinic_requirement": "complete_series_before_clinical_visit"
  },

  "data_handling_rules": {
    "required_actions": [
      "record_all_readings",
      "store_time_stamp",
      "label_morning_or_evening",
      "calculate_average_per_session"
    ],

    "reporting_requirement": {
      "patient_must_share_with_clinician": true
    }
  },

  "clinical_integrity_notes": {
    "objective": "reduce measurement variability and white-coat bias",
    "failure_modes": [
      "incorrect cuff placement",
      "insufficient rest period",
      "talking during measurement",
      "non-standard timing",
      "single-reading reliance"
    ]
  }
}