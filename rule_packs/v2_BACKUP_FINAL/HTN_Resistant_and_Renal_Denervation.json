{
  "module": "HTN_Resistant_and_Renal_Denervation",
  "version": "2025_full_guideline",
  "intent": "Diagnosis, escalation, and interventional selection for resistant hypertension and renal denervation",

  "definitions": {
    "resistant_hypertension": {
      "description": "BP above goal despite ≥3 antihypertensive classes at optimal doses including ACEi/ARB + CCB + thiazide-like diuretic",
      "required_classes": [
        "ACE_inhibitor_or_ARB",
        "calcium_channel_blocker",
        "thiazide_like_diuretic"
      ]
    },

    "optimal_triple_therapy": {
      "components": [
        "ACEi_or_ARB",
        "CCB",
        "thiazide_like_diuretic"
      ],
      "preferred_diuretics": [
        "chlorthalidone",
        "indapamide"
      ]
    }
  },

  "resistant_hypertension_management": {
    "step_1_evaluation": {
      "recommendation_class": "COR 1",
      "evidence_level": "LOE B-NR",
      "actions": [
        "evaluate_secondary_hypertension_causes",
        "review_all_current_medications",
        "identify_BP_interfering_drugs",
        "remove_interfering_agents_if_possible"
      ],
      "goal": "lower_BP_and_simplify_regimen"
    },

    "step_2_add_mra": {
      "recommendation_class": "COR 1",
      "evidence_level": "LOE B-R",
      "eligibility": {
        "requires_all": [
          "resistant_hypertension_present",
          "on_optimal_triple_therapy",
          "eGFR >= 45 ml/min/1.73m2"
        ]
      },
      "intervention": "add_MRA",
      "first_line_mra": "spironolactone_or_eplerenone",
      "goal": "BP_control_achieved"
    },

    "step_3_if_mra_not_possible": {
      "recommendation_class": "COR 2a",
      "evidence_level": "LOE B-NR",
      "conditions": [
        "MRA_intolerance",
        "MRA_contraindication"
      ],
      "alternative_agents": [
        "amiloride",
        "beta_blockers",
        "alpha_blockers",
        "central_sympatholytics",
        "dual_endothelin_receptor_antagonists",
        "direct_vasodilators"
      ],
      "goal": "BP_control_alternative_pathway"
    }
  },

  "renal_denervation": {
    "indication": {
      "recommendation_class": "COR 2b",
      "evidence_level": "LOE B-R",

      "eligibility_criteria": {
        "blood_pressure_range": {
          "office_sbp_mmHg": "140-180",
          "office_dbp_mmHg": ">=90"
        },

        "renal_function": {
          "eGFR_minimum": 40
        },

        "clinical_conditions": [
          "resistant_hypertension_despite_optimal_medical_therapy",
          "OR_intolerable_side_effects_to_additional_medications"
        ]
      },

      "context": [
        "adjunct_to_medication",
        "adjunct_to_lifestyle_modification"
      ]
    },

    "contraindication_screening": {
      "required_pre_evaluation": [
        "multidisciplinary_team_assessment",
        "secondary_hypertension_exclusion",
        "renal_vascular_imaging_review"
      ]
    },

    "shared_decision_making": {
      "recommendation_class": "COR 1",
      "evidence_level": "LOE C-EQ",
      "requirements": [
        "discuss_benefits_of_BP_reduction",
        "discuss_procedural_risks",
        "compare_with_continued_medical_therapy",
        "align_with_patient_preferences"
      ]
    }
  },

  "safety_engine": {
    "mandatory_exclusion_workup": [
      "secondary_hypertension_screening_required",
      "medication_interaction_review_required"
    ],

    "absolute_block_conditions": [
      "untreated_secondary_hypertension",
      "incomplete_multidrug_optimization",
      "unassessed_renal_vascular_anatomy"
    ]
  },

  "decision_engine": {
    "rule_1": "if_not_on_optimal_triple_therapy_then_optimize_medical_therapy_first",
    "rule_2": "if_MRA_not_tried_and_eligible_then_add_MRA_before_intervention",
    "rule_3": "if_MRA_failed_or_not_tolerated_and_criteria_met_then_consider_RDN",
    "rule_4": "RDN_requires_multidisciplinary_team_approval"
  },

  "care_lifecycle_mapping": {
    "primary_phase": "Treatment_Optimization",

    "allowed_transitions": {
      "to_diagnostic_expansion": "secondary_cause_suspected OR treatment_failure",
      "to_interventional_consideration": "resistant_hypertension_confirmed AND optimization_failed",
      "to_chronic_management": "BP_control_achieved",
      "to_complication_management": "target_organ_damage_detected"
    }
  },

  "navigation_engine": {
    "if_resistant_htn_initial": "hypertension_clinic",
    "if_secondary_suspected": "nephrology_or_endocrinology",
    "if_RDN_candidate": "interventional_cardiology_or_specialized_RDN_center",
    "if_multidisciplinary_review_needed": "resistant_hypertension_team"
  }
}