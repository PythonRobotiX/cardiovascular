{
  "module": "HTN_AND_Orthostatic_Hypotension_Management",
  "version": "ACC_AHA_2025",
  "scope": "Adults with hypertension and/or orthostatic hypotension",
  
  "definitions": {
    "orthostatic_hypotension": {
      "description": "Drop in BP upon standing; may be symptomatic or asymptomatic",
      "subtypes": ["symptomatic", "asymptomatic"]
    }
  },

  "clinical_context": {
    "target_population": [
      "hypertension",
      "intensive_bp_lowering_therapy"
    ]
  },

  "decision_rules": [

    {
      "id": "OH_001",
      "title": "BP control reduces OH risk",
      "type": "treatment_principle",
      "trigger_conditions": {
        "has_hypertension": true
      },
      "recommendation": {
        "action": "optimize_bp_control",
        "goal": "reduce_risk_of_orthostatic_hypotension"
      },
      "priority": "high",
      "evidence": {
        "COR": "I",
        "LOE": "A"
      },
      "layer_mapping": [
        "Orchestration",
        "Decision Engine"
      ]
    },

    {
      "id": "OH_002",
      "title": "Continue intensive BP control in asymptomatic OH",
      "type": "treatment_decision",
      "trigger_conditions": {
        "has_hypertension": true,
        "orthostatic_hypotension": "present",
        "oh_symptoms": false,
        "on_intensive_bp_therapy": true
      },
      "recommendation": {
        "action": "continue_bp_lowering_strategy",
        "target_sbp": "<130",
        "justification": "cardiovascular_and_mortality_benefit"
      },
      "priority": "moderate",
      "evidence": {
        "COR": "IIa",
        "LOE": "A"
      },
      "safety_notes": [
        "monitor_for_new_symptoms",
        "reassess_if_symptoms_develop"
      ],
      "layer_mapping": [
        "Decision Engine",
        "Safety Engine"
      ]
    },

    {
      "id": "OH_003",
      "title": "Assess for symptomatic OH when initiating or intensifying therapy",
      "type": "monitoring_rule",
      "trigger_conditions": {
        "has_hypertension": true,
        "therapy_change": [
          "initiation",
          "dose_increase",
          "new_medication_added"
        ],
        "target_sbp": "<130"
      },
      "recommendation": {
        "action": "assess_for_symptomatic_orthostatic_hypotension",
        "method": [
          "symptom_inquiry",
          "orthostatic_vitals_measurement"
        ],
        "purpose": "detect_underlying_conditions_or_intolerance"
      },
      "priority": "moderate",
      "evidence": {
        "COR": "IIa",
        "LOE": "B-R"
      },
      "outputs": {
        "if_positive": [
          "flag_symptomatic_OH",
          "trigger_clinical_reassessment",
          "consider_medication_adjustment"
        ],
        "if_negative": [
          "continue_current_plan"
        ]
      },
      "layer_mapping": [
        "Event Engine",
        "Safety Engine",
        "Care Lifecycle"
      ]
    }

  ],

  "safety_triggers": [
    {
      "condition": "orthostatic_hypotension == symptomatic",
      "actions": [
        "increase_monitoring_frequency",
        "review_medications",
        "evaluate_for_secondary_causes"
      ],
      "priority": "high"
    }
  ],

  "care_lifecycle_integration": {
    "applicable_phases": [
      "Treatment Initiation",
      "Treatment Optimization",
      "Follow-up / Surveillance"
    ],
    "notes": "OH assessment is critical during therapy changes and ongoing monitoring"
  }

}