{
  "module": "ACUTE_ICH_BP_MANAGEMENT",
  "version": "2025",
  "context": {
    "population": "adult",
    "condition": "acute_spontaneous_intracerebral_hemorrhage"
  },

  "state_definitions": [
    {
      "state": "ICH_SBP_150_220",
      "criteria": {
        "SBP_min": 150,
        "SBP_max": 220,
        "condition": "acute_ICH"
      }
    },
    {
      "state": "ICH_SBP_GT_220",
      "criteria": {
        "SBP_min": 220,
        "condition": "acute_ICH"
      }
    }
  ],

  "decision_rules": [
    {
      "id": "ICH_BP_LOWERING_150_220",
      "cor": "2a",
      "loe": "A",
      "trigger": {
        "state": "ICH_SBP_150_220"
      },
      "action": {
        "type": "blood_pressure_targeting",
        "target_SBP_range": {
          "min": 130,
          "max_exclusive": 140
        },
        "initiation": "immediate",
        "duration": ">=7_days"
      },
      "constraints": [
        {
          "type": "lower_bound_guard",
          "condition": "SBP < 130",
          "action": "stop_antihypertensives"
        }
      ],
      "expected_outcome": "improved_functional_outcomes"
    },

    {
      "id": "ICH_BP_TITRATION_STRATEGY",
      "cor": "2a",
      "loe": "B-NR",
      "trigger": {
        "condition": "acute_ICH",
        "requires_BP_lowering": true
      },
      "action": {
        "type": "titration_strategy",
        "properties": {
          "smooth_control": true,
          "avoid_variability": true,
          "avoid_peaks": true,
          "sustained_control": true
        }
      },
      "expected_outcome": "improved_functional_outcomes"
    },

    {
      "id": "ICH_BP_LOWER_BOUND_HARM_GT_220",
      "cor": "3_harm",
      "loe": "B-NR",
      "trigger": {
        "state": "ICH_SBP_GT_220"
      },
      "prohibition": {
        "type": "lower_bound_violation",
        "condition": "SBP < 130",
        "action": "do_not_lower_below_threshold"
      },
      "reason": "increased_adverse_events"
    }
  ],

  "safety_rules": [
    {
      "id": "ICH_BP_UNDER_TREATMENT_GUARD",
      "condition": {
        "SBP": "<130",
        "context": "acute_ICH_on_treatment"
      },
      "action": "stop_antihypertensives",
      "priority": "high"
    },
    {
      "id": "ICH_BP_VARIABILITY_ALERT",
      "condition": {
        "SBP_variability": "high"
      },
      "action": "alert_reduce_variability",
      "priority": "medium"
    }
  ],

  "care_lifecycle_mapping": {
    "phase": "Complication_Management",
    "entry_criteria": "acute_intracerebral_hemorrhage",
    "goals": [
      "prevent_hematoma_expansion",
      "optimize_functional_outcome",
      "avoid_hypoperfusion"
    ]
  },

  "navigation_rules": [
    {
      "condition": "acute_ICH",
      "route_to": [
        "emergency_department",
        "neurocritical_care_unit"
      ],
      "urgency": "immediate"
    }
  ]
}