{
  "id": "HTN.PREVENTION.NEUROCOG.MCI_DEMENTIA.V1",
  "title": "Prevention of Mild Cognitive Impairment and Dementia in Hypertension",
  "guideline_source": "ACC/AHA Hypertension Guideline 2025",

  "recommendation_class": {
    "COR": "1",
    "LOE": "A"
  },

  "clinical_rule_type": "prevention_target",

  "population": {
    "condition": "hypertension",
    "age_group": "adults"
  },

  "clinical_goal": {
    "primary_outcomes": [
      "prevent_mild_cognitive_impairment",
      "prevent_dementia"
    ]
  },

  "target_parameters": {
    "systolic_blood_pressure": {
      "target_value": 130,
      "operator": "<",
      "unit": "mmHg",
      "measurement_context": "standardized_office_or_equivalent_out_of_office_reading"
    }
  },

  "decision_logic": {
    "trigger_conditions": [
      {
        "condition": "patient.has_hypertension == true"
      }
    ],

    "action": {
      "type": "intensify_bp_control",
      "strategy": "achieve_sbp_below_target"
    }
  },

  "care_lifecycle_mapping": {
    "applicable_phases": [
      "Prevention",
      "Chronic_Maintenance",
      "Treatment_Optimization"
    ]
  },

  "domain_mapping": {
    "disease_module": "HTN",
    "subdomain": "neurovascular_outcomes"
  },

  "safety_considerations": {
    "monitor_for": [
      "hypotension",
      "cerebral_hypoperfusion_symptoms"
    ],
    "risk_modifiers": [
      "elderly_frailty",
      "autonomic_instability",
      "history_of_stroke"
    ]
  },

  "event_triggers": {
    "bp_threshold_breach": {
      "condition": "systolic_bp >= 130",
      "action": "recommend_treatment_escalation"
    }
  },

  "monitoring_and_follow_up": {
    "bp_recheck_interval": "2-4_weeks_after_therapy_change",
    "long_term_follow_up": "3-6_months_if_stable"
  },

  "navigation_logic": {
    "care_setting": "outpatient",
    "provider_types": [
      "primary_care",
      "cardiology_if_refractory_or_high_risk"
    ]
  },

  "patient_outputs": {
    "instructions": [
      "maintain_systolic_bp_below_130",
      "perform_home_bp_monitoring"
    ],
    "education_points": [
      "lower_blood_pressure_reduces_cognitive_decline_risk"
    ]
  }
}