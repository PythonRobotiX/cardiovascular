{
  "module": "ACUTE_ISCHEMIC_STROKE_BP_MGMT",
  "version": "2025_ACC_AHA",
  "domain": "neurology_cardiovascular_interface",
  "condition": "acute_ischemic_stroke",

  "rules": [
    {
      "id": "AIS_001",
      "name": "Maintain systemic perfusion",
      "cor": "1",
      "loe": "C-LD",
      "priority": "critical_supportive_care",

      "if": {
        "condition": "acute_ischemic_stroke",
        "hemodynamics": {
          "hypotension": true,
          "or_hypovolemia": true
        }
      },

      "then": {
        "action": "correct_bp_and_volume",
        "goal": "maintain_systemic_perfusion",
        "target": "organ_perfusion_adequate"
      },

      "safety_tags": ["shock_risk", "perfusion_dependency"],
      "navigation": "emergency_supportive_management"
    },

    {
      "id": "AIS_002",
      "name": "BP control before IV thrombolysis",
      "cor": "1",
      "loe": "B-NR",
      "priority": "time_sensitive_intervention",

      "if": {
        "condition": "acute_ischemic_stroke",
        "eligible_for_iv_thrombolysis": true,
        "blood_pressure": {
          "SBP": ">=185",
          "DBP": ">=110"
        }
      },

      "then": {
        "action": "lower_bp_before_thrombolysis",
        "targets": {
          "SBP": "<185",
          "DBP": "<110"
        },
        "maintenance_after_tpa": {
          "SBP": "<180",
          "DBP": "<105",
          "duration": "24_hours"
        }
      },

      "safety_tags": [
        "hemorrhagic_transformation_risk",
        "thrombolysis_safety_gate"
      ],

      "navigation": "stroke_unit_or_emergency_stroke_protocol"
    },

    {
      "id": "AIS_003",
      "name": "BP control during endovascular therapy",
      "cor": "2a",
      "loe": "B-NR",
      "priority": "procedure_support",

      "if": {
        "condition": "acute_ischemic_stroke",
        "undergoing_endovascular_treatment": true
      },

      "then": {
        "action": "maintain_bp_control",
        "target": {
          "SBP": "<=180",
          "DBP": "<=105"
        },
        "duration": "during_procedure_and_24h_post"
      },

      "outcome_goal": [
        "improve_functional_outcome",
        "reduce_mortality"
      ],

      "navigation": "interventional_stroke_care_unit"
    },

    {
      "id": "AIS_004",
      "name": "Moderate BP reduction without reperfusion therapy",
      "cor": "2b",
      "loe": "C-LD",
      "priority": "selective_intervention",

      "if": {
        "condition": "acute_ischemic_stroke",
        "SBP": ">=220",
        "DBP": ">=120",
        "no_thrombolysis": true,
        "no_endovascular_treatment": true,
        "no_other_urgent_condition": true
      },

      "then": {
        "action": "gradual_bp_reduction",
        "target_reduction": "15_percent",
        "time_window": "first_24_hours"
      },

      "safety_tags": [
        "permissive_hypertension_boundary"
      ],

      "navigation": "inpatient_stroke_monitoring"
    },

    {
      "id": "AIS_005",
      "name": "Avoid early BP treatment in moderate BP stroke",
      "cor": "3_no_benefit",
      "loe": "A",
      "priority": "do_not_initiate",

      "if": {
        "condition": "acute_ischemic_stroke",
        "SBP": "<220",
        "DBP": "<120",
        "no_thrombolysis": true,
        "no_endovascular_treatment": true,
        "no_urgent_comorbidity": true
      },

      "then": {
        "action": "do_not_initiate_antihypertensives",
        "time_window": "first_48_to_72_hours"
      },

      "clinical_rationale": "no_benefit_in_outcome_improvement",

      "navigation": "observation_only"
    },

    {
      "id": "AIS_006",
      "name": "Avoid aggressive BP lowering after successful reperfusion",
      "cor": "3_harm",
      "loe": "A",
      "priority": "harm_prevention",

      "if": {
        "condition": "acute_ischemic_stroke",
        "successful_reperfusion": true,
        "endovascular_treatment_done": true,
        "time_window": "24_to_72_hours_post_reperfusion"
      },

      "then": {
        "action": "avoid_sbp_lowering_below_threshold",
        "harm_threshold": {
          "SBP": "<140"
        }
      },

      "risk": "worsened_functional_outcome",

      "navigation": "post_reperfusion_monitoring"
    }
  ]
}