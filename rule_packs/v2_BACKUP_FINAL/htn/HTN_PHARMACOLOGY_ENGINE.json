          { "name": "clonidine_patch", "dose_mg_per_day": { "min": 0.1, "max": 0.3 }, "frequency": "weekly" },
          { "name": "methyldopa", "dose_mg_per_day": { "min": 250, "max": 1000 }, "frequency": "twice_daily" },
          { "name": "guanfacine", "dose_mg_per_day": { "min": 0.5, "max": 2 }, "frequency": "once_daily" }
