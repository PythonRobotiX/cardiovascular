            "drugs": [
              { "name": "nadolol", "dose_mg_per_day": { "min": 40, "max": 120 }, "frequency": "once_daily" },
              { "name": "propranolol_IR", "dose_mg_per_day": { "min": 80, "max": 160 }, "frequency": "twice_daily" },
              { "name": "propranolol_LA", "dose_mg_per_day": { "min": 80, "max": 160 }, "frequency": "once_daily" }
