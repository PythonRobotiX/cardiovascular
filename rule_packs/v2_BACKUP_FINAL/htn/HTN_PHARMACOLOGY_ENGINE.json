              { "name": "penbutolol", "dose_mg_per_day": { "min": 10, "max": 40 }, "frequency": "once_daily" },
              { "name": "pindolol", "dose_mg_per_day": { "min": 10, "max": 60 }, "frequency": "twice_daily" }
            ]
          },

          "COMBINED_ALPHA_BETA": {
            "preferred_conditions": ["HFrEF"],
            "drugs": [
              { "name": "carvedilol", "dose_mg_per_day": { "min": 12.5, "max": 50 }, "frequency": "twice_daily" },
              { "name": "carvedilol_phosphate", "dose_mg_per_day": { "min": 20, "max": 80 }, "frequency": "once_daily" },
              { "name": "labetalol", "dose_mg_per_day": { "min": 200, "max": 1200 }, "frequency": "twice_daily" }
            ]
          }
        }
      },

      "DIRECT_RENIN_INHIBITOR": {
        "avoid_combinations": ["ACE_INHIBITOR", "ARB"],
        "risk_flags": ["hyperkalemia", "renal_failure"],
        "contraindications": ["pregnancy"],
