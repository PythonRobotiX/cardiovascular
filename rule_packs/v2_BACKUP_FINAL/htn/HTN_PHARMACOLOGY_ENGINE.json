          { "name": "prazosin", "dose_mg_per_day": { "min": 2, "max": 20 }, "frequency": ["twice_daily", "three_times_daily"] },
          { "name": "terazosin", "dose_mg_per_day": { "min": 1, "max": 20 }, "frequency": ["once_daily", "twice_daily"] }
        ]
      },

      "CENTRAL_ACTING_AGENTS": {
        "last_line": true,
