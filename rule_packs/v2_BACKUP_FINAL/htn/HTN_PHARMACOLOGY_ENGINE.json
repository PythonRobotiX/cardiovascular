        "class_name": "Non-dihydropyridine calcium channel blockers",
        "not_first_line": true,
        "contraindications": [
          "HFrEF"
        ],
        "avoid_combinations": [
          "beta_blockers"
        ],
        "interaction_flags": [
          "CYP3A4_substrate",
          "CYP3A4_inhibitor"
        ],
        "risk_flags": [
          "bradycardia",
          "heart_block"
        ],
        "drugs": [
          { "name": "diltiazem_ER", "dose_mg_per_day": { "min": 120, "max": 360 }, "frequency": "once_daily" },
          { "name": "verapamil_IR", "dose_mg_per_day": { "min": 120, "max": 360 }, "frequency": "three_times_daily" },
          { "name": "verapamil_SR", "dose_mg_per_day": { "min": 120, "max": 360 }, "frequency": ["once_daily", "twice_daily"] },
          { "name": "verapamil_ER_delayed", "dose_mg_per_day": { "min": 100, "max": 300 }, "frequency": "evening_once_daily" }
        ]
      },

