        ],
        "contraindications": [
          "GFR_below_45"
        ],
        "drugs": [
          { "name": "amiloride", "dose_mg_per_day": { "min": 5, "max": 10 }, "frequency": ["once_daily", "twice_daily"] },
          { "name": "triamterene", "dose_mg_per_day": { "min": 50, "max": 100 }, "frequency": ["once_daily", "twice_daily"] }
        ]
      },

