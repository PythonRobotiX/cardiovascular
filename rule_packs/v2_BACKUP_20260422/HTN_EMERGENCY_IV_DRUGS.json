{
  "module": "HTN_EMERGENCY_IV_DRUGS",
  "version": "2025",
  "scope": "hypertensive_emergency_management",

  "general_population": {
    "drug_classes": [
      {
        "class": "CCB_DIHYDROPYRIDINE",
        "agents": [
          {
            "name": "nicardipine",
            "dose": {
              "initial": "5 mg/h",
              "titration": "increase by 2.5 mg/h every 5 min",
              "max": "15 mg/h"
            },
            "contraindications": ["advanced aortic stenosis"],
            "notes": [
              "no dose adjustment for age ≥65",
              "no negative inotropic or chronotropic effect"
            ]
          },
          {
            "name": "clevidipine",
            "dose": {
              "initial": "1-2 mg/h",
              "titration": "double every 90 sec until near target, then slower titration every 5-10 min",
              "max": "21 mg/h",
              "duration_limit": "72 h"
            },
            "contraindications": [
              "soy/egg allergy",
              "defective lipid metabolism",
              "acute pancreatitis"
            ],
            "notes": [
              "low reflex tachycardia",
              "no negative inotropic effect"
            ]
          }
        ]
      },

      {
        "class": "VASODILATOR_NITRIC_OXIDE",
        "agents": [
          {
            "name": "nitroprusside",
            "dose": {
              "initial": "0.3-0.5 mcg/kg/min",
              "titration": "increase by 0.5 mcg/kg/min every 5 min",
              "max": "10 mcg/kg/min"
            },
            "warnings": [
              "requires arterial BP monitoring",
              "tachyphylaxis",
              "cyanide toxicity risk",
              "thiocyanate toxicity risk"
            ],
            "contraindications": [
              "avoid in acute cerebrovascular disease if alternatives available"
            ],
            "special_risks": {
              "cyanide_toxicity": {
                "threshold": "≥3 mcg/kg/min or ≥3 days",
                "risk_factors": ["liver disease", "CKD"],
                "management": ["stop drug", "give sodium thiosulfate or cyanocobalamin"]
              }
            }
          },
          {
            "name": "nitroglycerin",
            "dose": {
              "initial": "5 mcg/min",
              "titration": "increase by 5 mcg/min every 3-5 min",
              "max": "200 mcg/min"
            },
            "indications": ["ACS", "pulmonary edema"],
            "contraindications": ["volume depletion"],
            "notes": ["tachyphylaxis"]
          }
        ]
      },

      {
        "class": "VASODILATOR_DIRECT",
        "agents": [
          {
            "name": "hydralazine",
            "dose": {
              "initial": "10 mg IV",
              "max_initial": "20 mg",
              "repeat": "every 4-6 h",
              "max_daily": "200 mg"
            },
            "notes": [
              "unpredictable response",
              "not first-line in most patients"
            ]
          }
        ]
      },

      {
        "class": "BETA_BLOCKER_SELECTIVE",
        "agents": [
          {
            "name": "esmolol",
            "dose": {
              "loading": "500-1000 mcg/kg/min over 1 min",
              "infusion": "start 50 mcg/kg/min",
              "titration": "increase by 50 mcg/kg/min",
              "max": "300 mcg/kg/min"
            },
            "contraindications": [
              "bradycardia",
              "decompensated HF",
              "concurrent beta-blocker use"
            ],
            "warnings": ["bronchospasm risk at high dose"]
          }
        ]
      },

      {
        "class": "BETA_BLOCKER_COMBINED",
        "agents": [
          {
            "name": "labetalol",
            "dose": {
              "bolus": "0.3-1.0 mg/kg (max 20 mg)",
              "infusion": "0.4-1.0 mg/kg/h",
              "max_daily": "300 mg"
            },
            "contraindications": [
              "reactive airway disease",
              "heart block",
              "bradycardia"
            ],
            "notes": [
              "useful in hyperadrenergic states",
              "may worsen HF"
            ]
          }
        ]
      },

      {
        "class": "ALPHA_BLOCKER",
        "agents": [
          {
            "name": "phentolamine",
            "dose": {
              "bolus": "5 mg IV",
              "repeat": "every 10 min",
              "max_daily": "50 mg"
            },
            "indications": [
              "pheochromocytoma",
              "cocaine toxicity",
              "MAOI interactions",
              "amphetamine overdose",
              "clonidine withdrawal"
            ]
          }
        ]
      },

      {
        "class": "DOPAMINE_AGONIST",
        "agents": [
          {
            "name": "fenoldopam",
            "dose": {
              "initial": "0.1-0.3 mcg/kg/min",
              "titration": "increase by 0.05-0.1 every 15 min",
              "max": "1.6 mcg/kg/min"
            },
            "contraindications": [
              "glaucoma",
              "intracranial hypertension",
              "sulfite allergy"
            ]
          }
        ]
      },

      {
        "class": "ACE_INHIBITOR",
        "agents": [
          {
            "name": "enalaprilat",
            "dose": {
              "initial": "1.25 mg IV over 5 min",
              "repeat": "every 6 h",
              "max_daily": "50 mg"
            },
            "contraindications": [
              "pregnancy",
              "acute MI",
              "bilateral renal artery stenosis"
            ],
            "warnings": [
              "may worsen kidney function",
              "slow onset",
              "unpredictable BP response"
            ]
          }
        ]
      }
    ]
  },

  "comorbidity_specific": [
    {
      "condition": "acute_aortic_dissection",
      "preferred_agents": ["esmolol", "labetalol"],
      "rules": [
        "beta blocker before vasodilator",
        "target SBP ≤120 mmHg within 20 min"
      ]
    },
    {
      "condition": "acute_pulmonary_edema",
      "preferred_agents": ["clevidipine", "nitroglycerin", "nitroprusside"],
      "contraindicated": ["beta_blockers"]
    },
    {
      "condition": "acute_coronary_syndrome",
      "preferred_agents": ["esmolol", "labetalol", "nicardipine", "nitroglycerin"],
      "warnings": [
        "avoid nitrates with PDE-5 inhibitors"
      ]
    },
    {
      "condition": "acute_kidney_injury",
      "preferred_agents": ["clevidipine", "fenoldopam", "nicardipine"]
    },
    {
      "condition": "preeclampsia_eclampsia",
      "preferred_agents": ["hydralazine", "labetalol", "nicardipine", "nifedipine"],
      "contraindicated": [
        "ACE_inhibitors",
        "ARB",
        "renin_inhibitors",
        "nitroprusside"
      ]
    },
    {
      "condition": "perioperative_hypertension",
      "preferred_agents": ["clevidipine", "esmolol", "nicardipine", "nitroglycerin"]
    },
    {
      "condition": "catecholamine_excess",
      "preferred_agents": ["clevidipine", "nicardipine", "phentolamine"]
    },
    {
      "condition": "acute_ICH",
      "preferred_agents": ["clevidipine", "nicardipine", "esmolol", "labetalol", "hydralazine"]
    },
    {
      "condition": "acute_ischemic_stroke",
      "preferred_agents": ["clevidipine", "nicardipine", "esmolol", "labetalol", "hydralazine"]
    }
  ]
}