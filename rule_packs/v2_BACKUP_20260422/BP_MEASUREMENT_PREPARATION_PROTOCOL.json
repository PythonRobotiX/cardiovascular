{
  "module": "BP_MEASUREMENT_PREPARATION_PROTOCOL",
  "version": "1.0",

  "purpose": "Standardized pre-measurement conditions to ensure valid blood pressure readings",

  "pre_measurement_restrictions": {
    "avoid_within_30_minutes": [
      {
        "factor": "smoking",
        "condition": "patient_smoked_within_30_minutes == true",
        "effect": "INVALID_READING_RISK"
      },
      {
        "factor": "caffeine",
        "condition": "caffeinated_beverage_consumed_within_30_minutes == true",
        "effect": "BP_ELEVATION_BIAS"
      },
      {
        "factor": "exercise",
        "condition": "physical_exercise_within_30_minutes == true",
        "effect": "BP_ELEVATION_BIAS"
      }
    ]
  },

  "patient_positioning_rules": {
    "cuff_application": {
      "requirement": "cuff_on_bare_arm",
      "validation_rule": "arm_clothing_present == false"
    },

    "arm_position": {
      "requirement": "arm_supported_at_heart_level",
      "validation_rule": "arm_height_relative_to_heart == 'level'",
      "failure_effect": "MEASUREMENT_ERROR"
    },

    "cuff_placement": {
      "requirement": "bottom_of_cuff_above_antecubital_fossa",
      "validation_rule": "cuff_position == 'correct_above_elbow_flexure'",
      "failure_effect": "MEASUREMENT_INACCURACY"
    }
  },

  "resting_state_requirements": {
    "pre_measurement_rest": {
      "duration_minutes": 5,
      "conditions": [
        "seated_position",
        "back_supported",
        "feet_flat_on_floor",
        "legs_uncrossed",
        "patient_relaxed"
      ],
      "validation_rules": [
        {
          "rule_id": "REST_1",
          "condition": "rest_duration_minutes < 5",
          "effect": "INCOMPLETE_REST_STATE"
        },
        {
          "rule_id": "REST_2",
          "condition": "patient_position != 'seated_supported_relaxed'",
          "effect": "PHYSIOLOGIC_BIAS_RISK"
        }
      ]
    }
  },

  "data_quality_engine_output": {
    "valid_reading_conditions": [
      "no_smoking_30min",
      "no_caffeine_30min",
      "no_exercise_30min",
      "correct_cuff_position",
      "arm_at_heart_level",
      "adequate_rest_5min"
    ],

    "invalid_reading_flags": [
      "rest_inadequate",
      "positioning_error",
      "recent_physiologic_stimulation"
    ]
  },

  "system_integration_mapping": {
    "domain_layer": "data_validation",
    "event_engine": "measurement_quality_filter",
    "interpretation_layer": "confidence_weighting",
    "safety_engine": "false_reading_prevention",
    "care_lifecycle": "input_quality_gate"
  }
}